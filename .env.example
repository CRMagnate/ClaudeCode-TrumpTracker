# ── LLM providers ────────────────────────────────────────────────
# Primary + fallback are tried in order on 429/5xx/timeout (I6).
GROQ_API_KEY=
GEMINI_API_KEY=
# Values: groq | gemini (fallback also accepts: none)
LLM_PRIMARY=groq
LLM_FALLBACK=gemini
GROQ_MODEL=llama-3.3-70b-versatile
GEMINI_MODEL=gemini-2.0-flash

# ── Alert channels (each activates only if its vars are present) ──
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Email option A: any SMTP (e.g. Gmail with an app password)
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=465
EMAIL_USER=
EMAIL_PASSWORD=
EMAIL_TO=

# Email option B: Resend free tier (takes precedence over SMTP if set)
RESEND_API_KEY=
RESEND_FROM=
RESEND_TO=

# ── Sources ──────────────────────────────────────────────────────
SOURCE_TRUTHSOCIAL_ENABLED=1
TRUTHSOCIAL_ARCHIVE_URL=https://ix.cnn.io/data/truth-social/truth_archive.json

# ── Alerting thresholds ──────────────────────────────────────────
# Signals below this confidence are stored but never alerted.
ALERT_MIN_CONFIDENCE=0.0
